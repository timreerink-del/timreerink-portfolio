---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Metrics from '../components/Metrics.astro';
import CaseGallery from '../components/CaseGallery.astro';

interface Props {
  entry: CollectionEntry<'cases'>;
  next?: CollectionEntry<'cases'>;
}

const { entry, next } = Astro.props;
const { data } = entry;
const { title, company, year, role, accent, tags, summary, hero, duration, team, metrics } = data;

const accentVar = `var(--c-${accent})`;
const nextSlug = next ? next.id.replace(/\.mdx$/, '') : null;
---

<Base
  title={`${title} — ${company} · Tim Reerink`}
  description={summary}
  caseColor={accentVar}
>
  <Nav caseTitle={`${company} · ${title}`} />

  <article class="case">
    <header class="case-hero">
      <div class="case-hero-media">
        <Image
          src={hero}
          alt=""
          widths={[800, 1200, 1600, 2000]}
          sizes="100vw"
          loading="eager"
          class="case-hero-img"
        />
        <span class="case-hero-wash" aria-hidden="true"></span>
      </div>

      <div class="case-hero-text container">
        <span class="mono case-eyebrow">
          <span style="color: var(--case-color);">{company}</span>
          <span class="dot" aria-hidden="true">·</span>
          <span>{year}</span>
          <span class="dot" aria-hidden="true">·</span>
          <span>{role}</span>
        </span>
        <h1 class="case-title serif-display">{title}</h1>
        <p class="case-summary">{summary}</p>
      </div>
    </header>

    <section class="case-meta container" aria-label="Project facts">
      <dl class="case-meta-grid">
        <div><dt class="mono">Role</dt><dd>{role}</dd></div>
        <div><dt class="mono">Year</dt><dd>{year}</dd></div>
        <div><dt class="mono">Duration</dt><dd>{duration}</dd></div>
        {team && <div><dt class="mono">Team</dt><dd>{team}</dd></div>}
        <div class="case-meta-tags">
          <dt class="mono">Tags</dt>
          <dd>
            <ul role="list">
              {tags.map(t => <li class="mono">{t}</li>)}
            </ul>
          </dd>
        </div>
      </dl>
    </section>

    <div class="case-body container">
      <slot />
    </div>

    {data.gallery && data.gallery.length > 0 && (
      <CaseGallery items={data.gallery} />
    )}

    {metrics && metrics.length > 0 && <Metrics metrics={metrics} />}

    {next && nextSlug && (
      <a
        href={`/work/${nextSlug}`}
        class="next-case"
        style={`--case-color: var(--c-${next.data.accent});`}
      >
        <div class="next-inner container">
          <span class="mono next-label">Next case · {String(next.data.order).padStart(2, '0')}</span>
          <h3 class="next-title serif-display">{next.data.title}</h3>
          <span class="mono next-meta">
            <span style="color: var(--case-color);">{next.data.company}</span>
            <span class="dot">·</span>
            <span>{next.data.year}</span>
          </span>
        </div>
      </a>
    )}
  </article>
</Base>

<style>
  .case { padding-top: 80px; }

  .case-hero {
    position: relative;
    min-height: clamp(420px, 70vh, 720px);
    display: grid;
    align-items: end;
  }

  .case-hero-media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: var(--bg);
  }
  .case-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .case-hero-wash {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      transparent 30%,
      color-mix(in oklab, var(--bg) 85%, transparent) 80%,
      var(--bg) 100%);
  }

  .case-hero-text {
    position: relative;
    z-index: 1;
    padding-block: clamp(48px, 8vw, 120px);
    display: grid;
    gap: 20px;
    max-width: 1200px;
  }

  .case-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
  }
  .case-eyebrow .dot { color: var(--line); }

  .case-title {
    font-size: var(--t-h1);
    margin: 0;
    max-width: 22ch;
    color: var(--fg);
    text-wrap: balance;
  }

  .case-summary {
    margin: 0;
    max-width: 60ch;
    font-size: clamp(17px, 1.4vw, 21px);
    color: var(--fg);
    line-height: 1.5;
  }

  .case-meta {
    padding-block: 40px;
    border-bottom: 1px solid var(--line);
  }
  .case-meta-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 24px;
    margin: 0;
  }
  .case-meta-grid > div { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .case-meta-grid dt { color: var(--muted); }
  .case-meta-grid dd { margin: 0; color: var(--fg); font-size: 15px; }
  .case-meta-tags ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .case-meta-tags li {
    padding: 5px 10px 4px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 10px;
    color: var(--muted);
    line-height: 1;
  }
  @media (max-width: 768px) {
    .case-meta-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .case-body {
    max-width: 720px;
    padding-block: clamp(64px, 8vw, 120px);
  }

  /* MDX content typography (scoped via :global) */
  .case-body :global(h2) {
    font-family: var(--serif);
    font-weight: 300;
    font-variation-settings: "opsz" 96, "SOFT" 50;
    font-size: var(--t-h2);
    line-height: 1.05;
    margin: clamp(48px, 6vw, 80px) 0 24px;
    color: var(--fg);
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .case-body :global(h2:first-child) { margin-top: 0; }

  .case-body :global(h2::before) {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--case-color);
    margin-bottom: 20px;
  }

  .case-body :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    font-style: italic;
    font-size: 24px;
    line-height: 1.2;
    margin: 40px 0 12px;
    color: var(--case-color);
  }

  .case-body :global(p) {
    font-size: 18px;
    line-height: 1.7;
    margin: 0 0 20px;
    color: var(--fg);
  }

  .case-body :global(strong) {
    font-weight: 500;
    color: var(--fg);
  }

  .case-body :global(em) {
    font-style: italic;
    color: var(--case-color);
  }

  .case-body :global(img) {
    width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 32px 0 12px;
    border: 1px solid var(--line);
    background: var(--bg-2);
  }
  .case-body :global(p:has(> img:only-child)) {
    /* Markdown wraps images in <p>; widen them out of the prose column */
    max-width: none;
    margin-inline: calc(50% - 50vw + var(--gutter));
    margin-block: 56px;
  }
  @media (min-width: 1100px) {
    .case-body :global(p:has(> img:only-child)) {
      margin-inline: -120px;
    }
  }
  .case-body :global(p > img) { margin: 0; }

  .case-body :global(blockquote) {
    margin: 32px 0;
    padding: 16px 24px;
    border-left: 3px solid var(--case-color);
    background: var(--bg-2);
    border-radius: 0 8px 8px 0;
  }
  .case-body :global(blockquote p) {
    font-style: italic;
    color: var(--muted);
    margin: 0;
  }

  .case-body :global(ul),
  .case-body :global(ol) {
    margin: 16px 0 24px;
    padding-left: 0;
    list-style: none;
  }
  .case-body :global(li) {
    position: relative;
    padding-left: 28px;
    margin-bottom: 10px;
    font-size: 17px;
    line-height: 1.6;
  }
  .case-body :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 14px;
    height: 1px;
    background: var(--case-color);
  }
  .case-body :global(ol) { counter-reset: olc; }
  .case-body :global(ol li) { counter-increment: olc; }
  .case-body :global(ol li::before) {
    content: counter(olc, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0;
    color: var(--case-color);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  .case-body :global(a) {
    color: var(--case-color);
    border-bottom: 1px solid color-mix(in oklab, var(--case-color) 50%, transparent);
    transition: border-color 200ms ease;
  }
  .case-body :global(a:hover) { border-bottom-color: var(--case-color); }

  .case-body :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 56px 0;
  }

  .case-body :global(code) {
    font-family: var(--mono);
    font-size: 0.9em;
    background: var(--bg-2);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Next case */
  .next-case {
    display: block;
    border-top: 1px solid var(--line);
    color: var(--fg);
    transition: background 240ms ease;
    isolation: isolate;
  }
  .next-case:hover { background: color-mix(in oklab, var(--case-color) 6%, var(--bg)); }

  .next-inner {
    padding-block: clamp(64px, 10vw, 140px);
    display: grid;
    gap: 16px;
    text-align: center;
    place-items: center;
  }

  .next-label { color: var(--muted); }

  .next-title {
    font-size: clamp(36px, 5vw, 72px);
    font-weight: 300;
    margin: 0;
    color: var(--fg);
    transition: color 240ms ease;
    max-width: 22ch;
    text-wrap: balance;
  }
  .next-case:hover .next-title { color: var(--case-color); }

  .next-meta {
    color: var(--muted);
    display: inline-flex;
    gap: 8px;
  }
  .next-meta .dot { color: var(--line); }
</style>
