---
import '@fontsource/hind/300.css';
import '@fontsource/hind/400.css';
import '@fontsource/hind/500.css';
import '@fontsource/hind/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  caseColor?: string;
}

const {
  title = 'Tim Reerink — Product Design Lead',
  description = 'Product Design Lead with 16+ years across ING, Just Eat Takeaway, Wallapop, ICEO, and Randstad. Building design organisations that ship.',
  ogImage = '/og/default.png',
  caseColor,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogUrl = new URL(ogImage, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta name="theme-color" content="#0c0c0e" />
  </head>
  <body style={caseColor ? `--case-color: ${caseColor};` : undefined}>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="scroll-progress" aria-hidden="true"></div>
    <slot />
    <Analytics />
    <script is:inline>
      // Console signature for fellow snoopers.
      (() => {
        try {
          const big = 'color:#5b78ff;font:600 14px/1.2 ui-monospace,monospace;letter-spacing:0.1em';
          const dim = 'color:#8a8a93;font:400 12px/1.4 ui-monospace,monospace';
          console.log('%cTR.%c — built without Framer.\nAstro · vanilla CSS · Vercel.\nIf you read source for fun, we should talk: timreerink@proton.me', big, dim);
        } catch (_) {}

        // Click TR. logo to cycle wordmarks.
        const logo = document.querySelector('.logo');
        if (logo) {
          const marks = ['TR.', 'TR/26', 'T·R', 'Tim.', 'TR. ✦'];
          let i = 0;
          const original = logo.textContent;
          logo.addEventListener('click', (e) => {
            // Only intercept if the user clicks the logo *while on the home page*,
            // otherwise let it act as a normal home link.
            if (location.pathname === '/' && !e.metaKey && !e.ctrlKey) {
              e.preventDefault();
              i = (i + 1) % marks.length;
              logo.textContent = marks[i];
              logo.style.transition = 'transform 200ms cubic-bezier(.5,1.6,.5,1)';
              logo.style.transform = 'scale(0.92) rotate(-4deg)';
              setTimeout(() => { logo.style.transform = ''; }, 220);
            }
          });
          // Restore on unload so back-navigations don't see a stale wordmark.
          window.addEventListener('beforeunload', () => { logo.textContent = original; });
        }
      })();
    </script>
  </body>
</html>
