---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'cases'>;
  number: number;
  total?: number;
}

const { entry, number, total } = Astro.props;
const { data, id } = entry;
const { title, company, year, accent, tags, summary, featured } = data;
const num = String(number).padStart(2, '0');
const totalStr = total ? `/${String(total).padStart(2, '0')}` : '';
const slug = id.replace(/\.mdx$/, '');
---

<a
  href={`/work/${slug}`}
  class:list={['card', { featured }]}
  style={`--case-color: var(--c-${accent});`}
  aria-label={`${title} — ${company} ${year}`}
>
  <figure class="card-art">
    <span class="card-art-watermark serif-display" aria-hidden="true">{num}</span>
    <header class="card-art-meta mono">
      <span class="card-art-dot" aria-hidden="true"></span>
      <span>{num}{totalStr}</span>
      <span class="card-art-sep" aria-hidden="true">—</span>
      <span class="card-art-co">{company.toUpperCase()}</span>
      <span class="card-art-sep" aria-hidden="true">·</span>
      <span>{year}</span>
    </header>
    <h3 class="card-art-title serif-display">{title}</h3>
    <span class="card-art-bar" aria-hidden="true"></span>
    <span class="card-wash" aria-hidden="true"></span>
  </figure>

  <div class="card-body">
    <p class="card-summary">{summary}</p>

    <footer class="card-foot">
      <ul class="card-tags mono" role="list">
        {tags.map(t => <li>{t}</li>)}
      </ul>
      <span class="card-arrow arrow-btn" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="19" x2="19" y2="5" />
          <polyline points="9 5 19 5 19 15" />
        </svg>
      </span>
    </footer>
  </div>
</a>

<style>
  .card {
    grid-column: span 1;
    display: grid;
    grid-template-rows: auto auto;
    gap: 24px;
    padding: 24px;
    border: 1px solid color-mix(in oklab, var(--fg) 8%, transparent);
    border-radius: 18px;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--fg) 4%, transparent), color-mix(in oklab, var(--fg) 1%, transparent)),
      color-mix(in oklab, var(--bg-2) 70%, transparent);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    color: var(--fg);
    transition: border-color 240ms ease, transform 240ms ease, background 240ms ease;
    isolation: isolate;
    box-shadow: inset 0 1px 0 0 color-mix(in oklab, var(--fg) 8%, transparent);
  }
  .card.featured { grid-column: 1 / -1; }

  .card:hover { border-color: var(--case-color); transform: translateY(-2px); }
  .card:hover .card-arrow { transform: rotate(-45deg); }
  .card:hover .card-art-title { color: var(--case-color); }
  .card:hover .card-wash { opacity: 0.06; }
  .card:hover .card-art-watermark { transform: translate(0, 0); opacity: 0.22; }
  .card:hover .card-art {
    border-color: color-mix(in oklab, var(--case-color) 50%, var(--line));
  }

  .card-art {
    position: relative;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
    background:
      radial-gradient(110% 80% at 0% 100%, color-mix(in oklab, var(--case-color) 22%, transparent) 0%, transparent 60%),
      radial-gradient(70% 60% at 100% 0%, color-mix(in oklab, var(--case-color) 10%, transparent) 0%, transparent 55%),
      var(--bg);
    transition: border-color 240ms ease;
  }
  .card.featured .card-art { aspect-ratio: 21 / 9; padding: 48px; }

  .card-art-watermark {
    position: absolute;
    right: -0.06em;
    bottom: -0.18em;
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(180px, 28vw, 360px);
    line-height: 0.78;
    letter-spacing: -0.04em;
    color: var(--case-color);
    opacity: 0.14;
    transform: translate(8px, 8px);
    transition: transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 600ms ease;
    pointer-events: none;
    user-select: none;
  }
  .card.featured .card-art-watermark { font-size: clamp(280px, 36vw, 560px); }

  .card-art-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.1em;
    z-index: 1;
  }
  .card-art-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--case-color);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--case-color) 18%, transparent);
  }
  .card-art-co { color: var(--case-color); font-weight: 500; }
  .card-art-sep { color: var(--line); }

  .card-art-title {
    margin: 0;
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(36px, 4.4vw, 60px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--fg);
    transition: color 240ms ease;
    text-wrap: balance;
    overflow-wrap: anywhere;
    z-index: 1;
  }
  .card.featured .card-art-title {
    font-size: clamp(56px, 7.2vw, 108px);
    line-height: 0.94;
    max-width: 22ch;
  }

  .card-art-bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background: var(--case-color);
    z-index: 2;
  }

  .card-wash {
    position: absolute;
    inset: 0;
    background: var(--case-color);
    mix-blend-mode: multiply;
    opacity: 0;
    transition: opacity 240ms ease;
    pointer-events: none;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-summary {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.5;
    max-width: 56ch;
  }

  .card-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .card-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .card-tags li {
    padding: 6px 10px 5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-size: 10px;
    line-height: 1;
  }

  .card-arrow {
    width: 48px;
    height: 48px;
  }
  .card-arrow svg { width: 18px; height: 18px; }

  @media (max-width: 768px) {
    .card { padding: 16px; }
    .card-art { padding: 20px; gap: 20px; aspect-ratio: auto; min-height: 260px; }
    .card.featured .card-art { padding: 24px; aspect-ratio: auto; min-height: 280px; }
    .card-art-watermark { font-size: clamp(140px, 38vw, 240px); }
    .card.featured .card-art-watermark { font-size: clamp(180px, 50vw, 320px); }
    .card.featured .card-art-title { font-size: clamp(36px, 9vw, 56px); }
    .card-foot { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
</style>
