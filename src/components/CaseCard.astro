---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'cases'>;
  number: number;
}

const { entry, number } = Astro.props;
const { data, id } = entry;
const { title, company, year, accent, tags, summary, hero, featured } = data;
const num = String(number).padStart(2, '0');
const slug = id.replace(/\.mdx$/, '');
---

<a
  href={`/work/${slug}`}
  class:list={['card', { featured }]}
  style={`--case-color: var(--c-${accent});`}
  aria-label={`${title} — ${company} ${year}`}
>
  <figure class="card-media">
    <Image
      src={hero}
      alt=""
      widths={[480, 800, 1200, 1600]}
      sizes={featured ? '(max-width: 768px) 100vw, 100vw' : '(max-width: 768px) 100vw, 50vw'}
      loading={number <= 2 ? 'eager' : 'lazy'}
      class="card-img"
    />
    <span class="card-wash" aria-hidden="true"></span>
  </figure>

  <div class="card-body">
    <header class="card-header mono">
      <span class="card-num">{num}</span>
      <span class="card-meta">
        <span class="card-company">{company}</span>
        <span class="dot">·</span>
        <span>{year}</span>
      </span>
    </header>

    <h3 class="card-title serif-display">
      <span>{title}</span>
    </h3>

    <p class="card-summary">{summary}</p>

    <footer class="card-foot">
      <ul class="card-tags mono" role="list">
        {tags.map(t => <li>{t}</li>)}
      </ul>
      <span class="card-arrow arrow-btn" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="19" x2="19" y2="5" />
          <polyline points="9 5 19 5 19 15" />
        </svg>
      </span>
    </footer>
  </div>
</a>

<style>
  .card {
    grid-column: span 1;
    display: grid;
    grid-template-rows: auto auto;
    gap: 24px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--bg-2);
    color: var(--fg);
    transition: border-color 240ms ease, transform 240ms ease, background 240ms ease;
    isolation: isolate;
  }
  .card.featured { grid-column: 1 / -1; }

  .card:hover { border-color: var(--case-color); transform: translateY(-2px); }
  .card:hover .card-arrow { transform: rotate(-45deg); }
  .card:hover .card-title span { color: var(--case-color); }
  .card:hover .card-wash { opacity: 0.18; }

  .card-media {
    position: relative;
    margin: 0;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--bg);
  }
  .card.featured .card-media { aspect-ratio: 21 / 9; }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .card:hover .card-img { transform: scale(1.03); }

  .card-wash {
    position: absolute;
    inset: 0;
    background: var(--case-color);
    mix-blend-mode: multiply;
    opacity: 0;
    transition: opacity 240ms ease;
    pointer-events: none;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
  }

  .card-num {
    color: var(--case-color);
    font-weight: 500;
  }

  .card-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .card-company { color: var(--case-color); font-weight: 500; }
  .card-meta .dot { color: var(--line); }

  .card-title {
    font-family: var(--serif);
    font-weight: 300;
    font-size: var(--t-h3);
    line-height: 1.05;
    margin: 0;
    color: var(--fg);
    transition: color 240ms ease;
  }
  .card-title span { transition: color 240ms ease; }

  .card.featured .card-title { font-size: var(--t-h2); }

  .card-summary {
    margin: 0;
    color: var(--muted);
    font-size: 16px;
    line-height: 1.5;
    max-width: 56ch;
  }

  .card-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .card-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .card-tags li {
    padding: 6px 10px 5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-size: 10px;
    line-height: 1;
  }

  .card-arrow {
    width: 48px;
    height: 48px;
  }
  .card-arrow svg { width: 18px; height: 18px; }

  @media (max-width: 768px) {
    .card { padding: 16px; }
    .card-foot { flex-direction: column; align-items: flex-start; gap: 12px; }
  }
</style>
