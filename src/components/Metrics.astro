---
interface Metric { label: string; value: string; }
interface Props { metrics: Metric[]; }
const { metrics } = Astro.props;
---

<section class="metrics container" aria-label="Outcome metrics">
  <header class="metrics-head mono">
    <span>Outcome</span>
    <span class="metrics-line" aria-hidden="true"></span>
  </header>
  <ul class="metrics-grid" role="list">
    {metrics.map(m => (
      <li class="metric">
        <span class="metric-value serif-display">{m.value}</span>
        <span class="metric-label mono">{m.label}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .metrics {
    padding-block: clamp(64px, 8vw, 120px);
    border-block: 1px solid var(--line);
  }

  .metrics-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(40px, 5vw, 64px);
    color: var(--muted);
  }
  .metrics-line { flex: 1; height: 1px; background: var(--line); }

  .metrics-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 2px solid var(--case-color);
  }

  .metric-value {
    font-size: clamp(48px, 6vw, 88px);
    font-weight: 300;
    color: var(--case-color);
    line-height: 1;
    font-variation-settings: "opsz" 144, "SOFT" 50;
  }

  .metric-label {
    color: var(--muted);
    font-size: var(--t-meta);
  }

  @media (max-width: 900px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .metrics-grid { grid-template-columns: 1fr; }
  }
</style>
