---
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="foot-inner container">
    <div class="foot-col">
      <span class="logo mono">TR.</span>
      <span class="mono foot-byline">© {year} Tim Reerink · Amsterdam</span>
    </div>

    <div class="foot-col foot-links mono" aria-label="Footer navigation">
      <a href="/#work">Work</a>
      <a href="/experiments">Experiments</a>
      <a href="/#about">About</a>
      <a href="/#contact">Contact</a>
      <a href="https://www.linkedin.com/in/timreerink/" target="_blank" rel="noopener">LinkedIn ↗</a>
    </div>

    <div class="foot-col foot-easter mono">
      <span>Built without Framer.</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>Astro · Vanilla CSS · Vercel</span>
    </div>
  </div>
</footer>

<style>
  .foot {
    border-top: 1px solid var(--line);
    padding-block: 40px;
    background: var(--bg);
  }

  .foot-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
    align-items: center;
  }

  .foot-col {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    color: var(--muted);
    font-size: var(--t-meta);
  }

  .foot-col:nth-child(2) { justify-content: center; flex-wrap: wrap; }
  .foot-col:last-child { justify-content: flex-end; }

  .foot-col .dot { color: var(--line); }

  .logo {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--fg);
  }

  .foot-links a {
    color: var(--muted);
    transition: color 200ms ease;
  }
  .foot-links a:hover { color: var(--fg); }

  @media (max-width: 768px) {
    .foot-inner { grid-template-columns: 1fr; gap: 16px; }
    .foot-col, .foot-col:nth-child(2), .foot-col:last-child {
      justify-content: flex-start;
    }
  }
</style>
