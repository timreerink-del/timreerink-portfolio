---
const year = new Date().getFullYear();
---

<header class="hero" aria-label="Introduction">
  <div class="hero-inner container">
    <div class="hero-meta mono">
      <span>Amsterdam, NL</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>{year}</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>Product Design Lead</span>
    </div>

    <h1 class="hero-title serif-display">
      Designing how
      <span class="accent italic" data-text="teams">teams</span>
      design
      <span class="accent italic" data-text="products">products</span>
      that
      <span class="accent italic" data-text="ship.">ship.</span>
    </h1>

    <div class="hero-foot">
      <p class="hero-bio">
        Sixteen years across <strong>ING</strong>, <strong>Just Eat Takeaway</strong>,
        <strong>Wallapop</strong>, <strong>ICEO</strong>, and now <strong>Randstad Global</strong>.
        I build design organisations that move from execution to strategy — and the
        tooling, rituals, and AI workflows that make that real.
      </p>
      <ul class="hero-tags mono" role="list">
        <li>Design Leadership</li>
        <li>Strategy</li>
        <li>Design Ops</li>
        <li>AI Tooling</li>
        <li>UI Craft</li>
      </ul>
    </div>
  </div>
</header>

<style>
  .hero {
    padding-top: clamp(120px, 16vh, 200px);
    padding-bottom: clamp(48px, 8vw, 96px);
  }

  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: clamp(40px, 6vw, 88px);
    color: var(--muted);
  }

  .hero-meta .dot { color: var(--line); }

  .hero-title {
    font-size: var(--t-display);
    font-weight: 300;
    margin: 0;
    max-width: 14ch;
    color: var(--fg);
  }

  .accent {
    position: relative;
    display: inline-block;
    color: var(--case-color);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 50;
    isolation: isolate;
    z-index: 1;
  }

  /* Heavy halo + chromatic split — both behind the sharp foreground */
  .accent::before,
  .accent::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    pointer-events: none;
    font: inherit;
    font-style: italic;
    font-variation-settings: inherit;
    will-change: transform, filter, opacity;
    z-index: -1;
  }

  /* Core out-of-focus halo in brand cobalt — drifts wide */
  .accent::before {
    color: var(--case-color);
    filter: blur(24px);
    opacity: 1;
    animation: hero-blur-a 11s ease-in-out infinite alternate;
  }

  /* Cyan chromatic split — counter-phase, screen-blended for film vibe */
  .accent::after {
    color: #5cf2ff;
    mix-blend-mode: screen;
    filter: blur(9px);
    opacity: 0.65;
    animation: hero-blur-b 9s ease-in-out infinite alternate;
  }

  @keyframes hero-blur-a {
    0%   { transform: translate(0, 0);      filter: blur(18px); opacity: 0.75; }
    30%  { transform: translate(7px, -5px); filter: blur(32px); opacity: 1;    }
    60%  { transform: translate(-6px, 6px); filter: blur(14px); opacity: 0.65; }
    100% { transform: translate(4px, 2px);  filter: blur(26px); opacity: 0.9;  }
  }

  @keyframes hero-blur-b {
    0%   { transform: translate(5px, -1px);  opacity: 0.45; filter: blur(7px);  }
    40%  { transform: translate(-7px, 4px);  opacity: 0.85; filter: blur(11px); }
    70%  { transform: translate(3px, -5px);  opacity: 0.35; filter: blur(8px);  }
    100% { transform: translate(-4px, 2px);  opacity: 0.6;  filter: blur(9px);  }
  }

  @media (prefers-reduced-motion: reduce) {
    .accent::before,
    .accent::after { animation: none; }
    .accent::before { transform: none; opacity: 0.9;  filter: blur(22px); }
    .accent::after  { transform: none; opacity: 0.55; filter: blur(8px);  }
  }

  .hero-foot {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    margin-top: clamp(48px, 8vw, 96px);
    padding-top: 32px;
    border-top: 1px solid var(--line);
    align-items: start;
  }

  .hero-bio {
    margin: 0;
    max-width: 56ch;
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.55;
    color: var(--fg);
  }

  .hero-bio strong {
    font-weight: 400;
    font-style: italic;
    color: var(--case-color);
  }

  .hero-tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-self: end;
  }

  .hero-tags li {
    padding: 7px 12px 6px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-2);
    color: var(--muted);
    line-height: 1;
  }

  @media (max-width: 768px) {
    .hero-foot {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-tags { justify-self: start; }
  }
</style>
