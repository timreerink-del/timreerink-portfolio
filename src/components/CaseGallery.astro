---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryItem {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  items: GalleryItem[];
  label?: string;
  title?: string;
}

const { items, label = 'Redesign results', title = 'How it shipped.' } = Astro.props;
---

<section class="gallery container" aria-labelledby="gallery-h">
  <header class="gallery-head">
    <span class="mono gallery-label">{label}</span>
    <h2 id="gallery-h" class="gallery-title serif-display">
      <span class="italic">{title}</span>
    </h2>
    <span class="mono gallery-hint">Scroll →</span>
  </header>

  <ol class="gallery-track" role="list">
    {items.map((item, i) => (
      <li class="gallery-slide">
        <figure class="slide-figure">
          <span class="slide-num mono">
            {String(i + 1).padStart(2, '0')} / {String(items.length).padStart(2, '0')}
          </span>
          <Image
            src={item.src}
            alt={item.alt}
            widths={[600, 1000, 1600]}
            sizes="(max-width: 768px) 88vw, 70vw"
            loading={i === 0 ? 'eager' : 'lazy'}
            class="slide-img"
          />
          {item.caption && (
            <figcaption class="slide-caption mono">{item.caption}</figcaption>
          )}
        </figure>
      </li>
    ))}
  </ol>
</section>

<style>
  .gallery {
    padding-block: clamp(64px, 10vw, 120px);
    border-block: 1px solid var(--line);
    /* Allow track to bleed outside container while head stays inside */
    position: relative;
  }

  .gallery-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: clamp(32px, 4vw, 56px);
    flex-wrap: wrap;
  }
  .gallery-label { color: var(--muted); }
  .gallery-hint  { color: var(--muted); }
  .gallery-title {
    font-family: var(--serif);
    font-size: var(--t-h2);
    font-weight: 600;
    margin: 0;
    color: var(--fg);
    flex: 1 1 auto;
  }
  .gallery-title .italic {
    color: var(--case-color);
    font-weight: 600;
  }

  .gallery-track {
    list-style: none;
    margin: 0;
    padding: 0 var(--gutter);
    display: flex;
    gap: 24px;
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: var(--case-color) transparent;
    /* Bleed out of container */
    margin-inline: calc(50% - 50vw);
    padding-block: 8px 24px;
    scroll-padding-left: var(--gutter);
  }
  .gallery-track::-webkit-scrollbar { height: 4px; }
  .gallery-track::-webkit-scrollbar-track { background: transparent; }
  .gallery-track::-webkit-scrollbar-thumb {
    background: var(--case-color);
    border-radius: 4px;
  }

  .gallery-slide {
    flex: 0 0 auto;
    width: clamp(280px, 70vw, 1120px);
    scroll-snap-align: start;
  }

  .slide-figure {
    margin: 0;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-2);
    position: relative;
    transition: border-color 240ms ease, transform 240ms ease;
  }
  .slide-figure:hover { border-color: var(--case-color); }

  .slide-num {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    color: var(--case-color);
    background: color-mix(in oklab, var(--bg) 60%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 6px 10px 5px;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--case-color) 40%, transparent);
    font-size: 10px;
    line-height: 1;
  }

  .slide-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .slide-caption {
    padding: 14px 18px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    background: var(--bg);
  }

  @media (max-width: 768px) {
    .gallery-slide { width: 88vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-track { scroll-behavior: auto; }
  }
</style>
